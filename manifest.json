{
  "name": "扇贝助手v2",
  "version": "2.3.0",
  "author": "maicss maicss@foxmail.com https://github.com/maicss",
  "manifest_version": 3,
  "description": "基于shanbay网页API查询并加入单词到生词本的应用",
  "icons": {
    "48": "images/icon_48.png"
  },
  "background": {
    "service_worker": "js/background.js",
    "type": "module"
  },
  "commands": {
    "look-up-in-shanbay": {
      "description": "Look up a word in shanbay"
    }
  },
  "action": {
    "default_icon": "images/icon_48.png",
    "default_popup": "popup.html",
    "default_title": "扇贝助手v2"
  },
  "minimum_chrome_version": "88",
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "js/const.mjs",
        "js/main.mjs"
      ]
    }
  ],
  "content_scripts": [
    {
      "css": [
        "css/popover.css"
      ],
      "js": [
        "js/content-loader.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "exclude_matches": [
        "*://*.shanbay.com/*",
        "*://*.hjenglish.com/*",
        "*://*.codepen.io/*",
        "*://*.jsfiddle.net/*",
        "*://*.jsbin.com/*",
        "*://*.codesandbox.io/*",
        "*://*.github1s.com/*"
      ]
    },
    {
      "js": [
        "js/auth-bridge.js"
      ],
      "matches": [
        "*://*.shanbay.com/*",
        "*://shanbay.com/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "*://*.shanbay.com/*",
    "*://shanbay.com/*",
    "https://apiv3.shanbay.com/*",
    "https://web.shanbay.com/*",
    "*://*.baydn.com/*",
    "*://*.qiniucdn.com/*",
    "*://*.aliyuncs.com/*"
  ],
  "permissions": [
    "cookies",
    "contextMenus",
    "storage",
    "alarms",
    "notifications",
    "scripting",
    "activeTab"
  ]
}